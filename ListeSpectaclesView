package view;

import javafx.application.Application;
import javafx.collections.FXCollections;
import javafx.collections.ObservableList;
import javafx.geometry.Insets;
import javafx.scene.Scene;
import javafx.scene.control.Button;
import javafx.scene.control.TableColumn;
import javafx.scene.control.TableView;
import javafx.scene.control.cell.PropertyValueFactory;
import javafx.scene.layout.VBox;
import javafx.stage.Stage;
import model.Spectacle;

import java.util.List;

public class ListeSpectaclesView extends Application {

    @Override
    public void start(Stage stage) {
        VBox root = new VBox(10);
        root.setPadding(new Insets(15));

        TableView<Spectacle> table = new TableView<>();

        TableColumn<Spectacle, String> colTitre = new TableColumn<>("Titre");
        colTitre.setCellValueFactory(new PropertyValueFactory<>("titre"));

        TableColumn<Spectacle, String> colSalle = new TableColumn<>("Salle");
        colSalle.setCellValueFactory(new PropertyValueFactory<>("salle"));

        TableColumn<Spectacle, String> colDate = new TableColumn<>("Date");
        colDate.setCellValueFactory(new PropertyValueFactory<>("date"));

        TableColumn<Spectacle, Double> colPrix = new TableColumn<>("Prix");
        colPrix.setCellValueFactory(new PropertyValueFactory<>("prix"));

        table.getColumns().addAll(colTitre, colSalle, colDate, colPrix);

        List<Spectacle> spectacles = Spectacle.getAll();
        ObservableList<Spectacle> data = FXCollections.observableArrayList(spectacles);
        table.setItems(data);

        Button btnDetails = new Button("Voir détails");
        Button btnAcheter = new Button("Acheter un billet");

        btnDetails.setOnAction(e -> {
            Spectacle selected = table.getSelectionModel().getSelectedItem();
            if (selected != null) {
                new SpectacleDetailsView(selected).show();
            }
        });

        btnAcheter.setOnAction(e -> {
            Spectacle selected = table.getSelectionModel().getSelectedItem();
            if (selected != null) {
                new AchatBilletView(selected).show();
            }
        });

        root.getChildren().addAll(table, btnDetails, btnAcheter);

        Scene scene = new Scene(root, 600, 400);
        stage.setScene(scene);
        stage.setTitle("Liste des spectacles");
        stage.show();
    }

    public static void main(String[] args) {
        launch(args);
    }
}
