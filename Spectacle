package model;

import java.sql.*;
import java.util.ArrayList;
import java.util.List;

public class Spectacle {
    private int id;
    private String titre;
    private String salle;
    private String date;
    private double prix;

    public Spectacle(int id, String titre, String salle, String date, double prix) {
        this.id = id;
        this.titre = titre;
        this.salle = salle;
        this.date = date;
        this.prix = prix;
    }

    public int getId() { return id; }
    public String getTitre() { return titre; }
    public String getSalle() { return salle; }
    public String getDate() { return date; }
    public double getPrix() { return prix; }

    public static List<Spectacle> getAll() {
        List<Spectacle> spectacles = new ArrayList<>();
        try (Connection conn = Database.getConnection();
             Statement stmt = conn.createStatement();
             ResultSet rs = stmt.executeQuery(
                     "SELECT s.id_spectacle, s.titre, sl.nom AS salle, s.date_evenement, s.prix " +
                             "FROM spectacle s JOIN salle sl ON s.id_salle = sl.id_salle")) {

            while (rs.next()) {
                spectacles.add(new Spectacle(
                        rs.getInt("id_spectacle"),
                        rs.getString("titre"),
                        rs.getString("salle"),
                        rs.getString("date_evenement"),
                        rs.getDouble("prix")
                ));
            }

        } catch (SQLException e) {
            e.printStackTrace();
        }
        return spectacles;
    }

    public static void main(String[] args) {
        List<Spectacle> spectacles = getAll();
        if (spectacles.isEmpty()) {
            System.out.println("Aucun spectacle trouvé !");
        } else {
            System.out.println("Liste des spectacles :");
            for (Spectacle s : spectacles) {
                System.out.println(
                        s.getId() + " | " +
                                s.getTitre() + " | " +
                                s.getSalle() + " | " +
                                s.getDate() + " | " +
                                s.getPrix()
                );
            }
        }
    }
}
