<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21.0.9"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="view.SpectacleDetailsViewController"
      spacing="15" alignment="CENTER" style="-fx-padding: 20;">

    <Label fx:id="lblTitre" style="-fx-font-size: 18; -fx-font-weight: bold;"/>

    <VBox spacing="8" alignment="CENTER_LEFT">
        <Label fx:id="lblDate" style="-fx-font-size: 14;"/>
        <Label fx:id="lblHeure" style="-fx-font-size: 14;"/>
        <Label fx:id="lblSalle" style="-fx-font-size: 14;"/>
        <Label fx:id="lblDuree" style="-fx-font-size: 14;"/>
        <Label fx:id="lblLangue" style="-fx-font-size: 14;"/>
    </VBox>

</VBox>