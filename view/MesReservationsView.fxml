<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" style="-fx-padding: 25; -fx-background-color: #ffffff;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="view.MesReservationsController">
    <children>
        <Label text="🎟️ Mes Billets Réservés" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #6c5ce7;"/>

        <TableView fx:id="tableBillets" VBox.vgrow="ALWAYS" style="-fx-background-radius: 8; -fx-border-color: #dfe6e9;">
            <columns>
                <TableColumn fx:id="colSpectacle" text="Spectacle" prefWidth="220" />
                <TableColumn fx:id="colPlace" text="Place" prefWidth="80" />
                <TableColumn fx:id="colDateAchat" text="Date d'achat" prefWidth="160" />
                <TableColumn fx:id="colPrix" text="Prix Payé" prefWidth="100" />
                <TableColumn fx:id="colStatut" text="Statut" prefWidth="100" />
            </columns>
        </TableView>

        <HBox alignment="CENTER_RIGHT" spacing="10">
            <Button text="Annuler Réservation" onAction="#handleSupprimer"
                    style="-fx-background-color: #ff7675; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 5;"/>

            <Button text="Fermer" onAction="#handleClose"
                    style="-fx-background-color: #b2bec3; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 5;"/>
        </HBox>
    </children>
</VBox>