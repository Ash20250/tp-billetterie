<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.cell.PropertyValueFactory?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="src.main.ressources.view.ClientListController"
            stylesheets="@style.css">

    <top>
        <HBox spacing="8">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <TextField fx:id="searchField" promptText="Rechercher par nom..." />
            <Button fx:id="searchButton" text="Rechercher" />
            <Button fx:id="refreshButton" text="Actualiser" />
        </HBox>
    </top>

    <center>
        <TableView fx:id="tableClients">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="60" />
                <TableColumn fx:id="colPrenom" text="Prénom" prefWidth="120" />
                <TableColumn fx:id="colNom" text="Nom" prefWidth="140" />
                <TableColumn fx:id="colEmail" text="Email" prefWidth="200" />
                <TableColumn fx:id="colAdresse" text="Adresse" prefWidth="200" />
                <TableColumn fx:id="colNumTel" text="Téléphone" prefWidth="120" />
            </columns>
        </TableView>
    </center>

    <bottom>
        <HBox spacing="8">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <Button fx:id="addButton" text="Ajouter" />
            <Button fx:id="editButton" text="Modifier" />
            <Button fx:id="deleteButton" text="Supprimer" />
            <Button fx:id="detailsButton" text="Voir profil" />
        </HBox>
    </bottom>

</BorderPane>
