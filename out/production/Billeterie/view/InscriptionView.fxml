<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" spacing="15.0" prefHeight="500.0" prefWidth="400.0"
      xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="view.InscriptionViewController" style="-fx-background-color: #f4f4f4;">

    <Text text="Créer un compte" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

    <GridPane vgap="10" hgap="10" alignment="CENTER">
        <Label text="Nom :" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="txtNom" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Prénom :" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="txtPrenom" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Email :" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="txtEmail" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Mot de passe :" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <PasswordField fx:id="txtPassword" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
    </GridPane>

    <Button text="S'inscrire" onAction="#handleInscription"
            style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-padding: 10 20; -fx-cursor: hand;"/>

    <Hyperlink text="Retour à la connexion" onAction="#goToLogin"/>
</VBox>