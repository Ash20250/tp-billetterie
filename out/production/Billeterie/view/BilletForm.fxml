<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.*?>

<VBox xmlns="http://javafx.com/javafx/21.0.9"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="src.main.ressources.view.BilletFormController"
      spacing="12" alignment="CENTER" style="-fx-padding:20;">

    <Label text="Acheter un billet" style="-fx-font-size:18; -fx-font-weight:bold;"/>

    <HBox spacing="10">
        <Label text="Séance:"/>
        <ComboBox fx:id="comboSeance" prefWidth="250"/>
    </HBox>

    <HBox spacing="10">
        <Label text="Client:"/>
        <ComboBox fx:id="comboClient" prefWidth="250"/>
    </HBox>

    <HBox spacing="10">
        <Label text="Nombre de billets:"/>
        <Spinner fx:id="spinnerQuantite" prefWidth="80"/>
    </HBox>

    <HBox spacing="10">
        <Label text="Prix total:"/>
        <Label fx:id="lblPrixTotal" text="0.00 €"/>
    </HBox>

    <Button fx:id="btnValider" text="Valider l'achat" onAction="#validerAchat" style="-fx-font-weight:bold;"/>
</VBox>