<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="src.main.ressources.view.SpectacleFormController" spacing="10">
    <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>

    <Label text="Créer / Modifier un Spectacle" style="-fx-font-size: 18px; -fx-font-weight: bold;" />

    <TextField fx:id="fieldTitre" promptText="Titre du spectacle" />
    <TextField fx:id="fieldDuree" promptText="Durée (minutes)" />
    <TextField fx:id="fieldLangue" promptText="Langue" />
    <TextField fx:id="fieldAgeMin" promptText="Âge minimum" />
    <DatePicker fx:id="fieldDateEvenement" promptText="Date de l'évènement" />
    <TextField fx:id="fieldCategorie" promptText="Catégorie" />
    <TextArea fx:id="fieldDescriptionCourte" promptText="Description courte" />
    <TextArea fx:id="fieldDescriptionLongue" promptText="Description longue" />

    <ComboBox fx:id="comboSalle" promptText="Salle" />

    <Button fx:id="btnValider" text="Valider" />
</VBox>