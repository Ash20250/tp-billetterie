<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.GridPane?>

<GridPane xmlns="http://javafx.com/javafx/21.0.9"
          xmlns:fx="http://javafx.com/fxml"
          fx:controller="view.ClientFormController"
          hgap="10" vgap="10" style="-fx-padding:20;">

    <Label text="Prénom" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
    <TextField fx:id="fieldPrenom" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

    <Label text="Nom" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
    <TextField fx:id="fieldNom" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

    <Label text="Email" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
    <TextField fx:id="fieldEmail" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

    <Label text="Adresse" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
    <TextField fx:id="fieldAdresse" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

    <Label text="Téléphone" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
    <TextField fx:id="fieldNumTel" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

    <Button fx:id="btnValider" text="Valider" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
</GridPane>