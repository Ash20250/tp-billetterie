<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="view.ListeSpectaclesViewController" spacing="10.0">
    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
    <Label text="Liste des Spectacles" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
    <TableView fx:id="tableSpectacles" prefHeight="400">
        <columns>
            <TableColumn text="Titre" fx:id="colTitre" />
            <TableColumn text="Salle" fx:id="colSalle" />
            <TableColumn text="Date" fx:id="colDate" />
        </columns>
    </TableView>
    <Button text="Voir le détail" fx:id="btnVoirDetail" />
</VBox>
