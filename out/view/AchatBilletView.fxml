<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="view.AchatBilletViewController" spacing="10">
    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
    <Label text="Acheter un billet" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
    <GridPane hgap="10" vgap="10">
        <Label text="Spectacle:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <ComboBox fx:id="comboSpectacle" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
        <Label text="Séance:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <ComboBox fx:id="comboSeance" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
        <Label text="Client:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <ComboBox fx:id="comboClient" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
    </GridPane>
    <Button text="Confirmer l'achat" fx:id="btnConfirmer"/>
</VBox>
