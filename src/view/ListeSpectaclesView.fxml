<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" style="-fx-padding: 20; -fx-background-color: #f4f4f4;"
      xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="view.ListeSpectaclesViewController">

    <children>
        <HBox alignment="CENTER_LEFT" spacing="15">
            <children>
                <Label fx:id="lblUtilisateur" text="Session : Non connecté"
                       style="-fx-text-fill: #7f8c8d; -fx-font-style: italic; -fx-font-size: 14px;"/>
                <Region HBox.hgrow="ALWAYS" />
                <Button text="Se déconnecter" onAction="#handleLogout"
                        style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5;"/>
            </children>
        </HBox>

        <Label text="Spectacles Disponibles" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: white; -fx-padding: 10; -fx-background-radius: 5; -fx-border-color: #dcdde1; -fx-border-radius: 5;">
            <children>
                <Label text="🔍" style="-fx-font-size: 16px;"/>
                <TextField fx:id="filterField" promptText="Rechercher par titre de spectacle ou par salle..."
                           HBox.hgrow="ALWAYS"
                           style="-fx-background-color: transparent; -fx-prompt-text-fill: #95a5a6;"/>
            </children>
        </HBox>

        <TableView fx:id="tableSpectacles" VBox.vgrow="ALWAYS" prefHeight="400.0" style="-fx-background-radius: 5;">
            <columns>
                <TableColumn fx:id="colTitre" text="Titre" prefWidth="200" />
                <TableColumn fx:id="colDate" text="Date" prefWidth="120" />
                <TableColumn fx:id="colHeure" text="Heure" prefWidth="100" />
                <TableColumn fx:id="colSalle" text="Salle" prefWidth="150" />
                <TableColumn fx:id="colPlaces" text="Places" prefWidth="100" />
            </columns>
        </TableView>

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <children>
                <Button fx:id="btnAjouter" text="Ajouter" onAction="#handleAjouter"
                        style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;"
                        visible="false" managed="false"/>

                <Button fx:id="btnModifier" text="Modifier" onAction="#handleModifier"
                        style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-weight: bold;"
                        visible="false" managed="false"/>

                <Button fx:id="btnSupprimer" text="Supprimer" onAction="#handleSupprimer"
                        style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-font-weight: bold;"
                        visible="false" managed="false"/>

                <Button fx:id="btnVoirClient" text="Voir Client" onAction="#handleGestionClients"
                        style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-font-weight: bold;"
                        visible="false" managed="false"/>

                <Button fx:id="btnMesReservations" text="Mes Réservations" onAction="#handleMesReservations"
                        style="-fx-background-color: #9b59b6; -fx-text-fill: white; -fx-font-weight: bold;"
                        visible="false" managed="false"/>

                <Button fx:id="btnAcheterBillet" text="Acheter Billet" onAction="#handleAcheterBillet"
                        style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold;"
                        visible="false" managed="false"/>

                <Button text="Rafraîchir" onAction="#chargerDonnees"
                        style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;"/>

                <Button fx:id="btnVoirDetails" text="Voir Détails" onAction="#handleVoirDetails"
                        style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold;"/>
            </children>
        </HBox>
    </children>
</VBox>