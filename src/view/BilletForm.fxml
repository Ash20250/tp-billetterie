<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.*?>

<VBox xmlns="http://javafx.com/javafx/21.0.9"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="view.BilletFormController"
      spacing="12" alignment="CENTER" style="-fx-padding:20;">

    <Label text="Acheter un billet" style="-fx-font-size:18; -fx-font-weight:bold;"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Séance:" prefWidth="120"/>
        <ComboBox fx:id="comboSeance" prefWidth="250"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Client:" prefWidth="120"/>
        <ComboBox fx:id="comboClient" prefWidth="250"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Nombre de billets:"/>
        <Spinner fx:id="spinnerQuantite" prefWidth="80"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Prix total:"/>
        <Label fx:id="lblPrixTotal" text="0.00 €" style="-fx-font-weight: bold;"/>
    </HBox>

    <HBox spacing="15" alignment="CENTER" style="-fx-padding: 10 0 0 0;">
        <Button fx:id="btnValider" text="Valider l'achat"
                onAction="#validerAchat"
                style="-fx-font-weight:bold; -fx-background-color: #2ecc71; -fx-text-fill: white;"/>

        <Button text="Déconnexion"
                onAction="#handleLogout"
                style="-fx-font-weight:bold; -fx-background-color: #e74c3c; -fx-text-fill: white;"/>
    </HBox>

</VBox>