<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.cell.PropertyValueFactory?>

<VBox xmlns="http://javafx.com/javafx/21.0.9"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="view.ClientListController"
      spacing="10" alignment="CENTER" style="-fx-padding:20;">

    <Label text="Liste des Clients" style="-fx-font-size:18; -fx-font-weight:bold;"/>

    <HBox spacing="10">
        <TextField fx:id="searchField" promptText="Rechercher par nom ou prénom" prefWidth="300"/>
        <!-- Vérifie bien que cette méthode existe dans ton contrôleur Java -->
        <Button fx:id="searchButton" text="Rechercher" onAction="#handleRechercher"/>
        <Button fx:id="refreshButton" text="Rafraîchir" onAction="#handleRafraichir"/>
    </HBox>

    <TableView fx:id="tableClients" prefHeight="400" prefWidth="700">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="50">
                <cellValueFactory><PropertyValueFactory property="id_client" /></cellValueFactory>
            </TableColumn>
            <TableColumn fx:id="colPrenom" text="Prénom" prefWidth="120">
                <cellValueFactory><PropertyValueFactory property="prenom" /></cellValueFactory>
            </TableColumn>
            <TableColumn fx:id="colNom" text="Nom" prefWidth="120">
                <cellValueFactory><PropertyValueFactory property="nom" /></cellValueFactory>
            </TableColumn>
            <TableColumn fx:id="colEmail" text="Email" prefWidth="180">
                <cellValueFactory><PropertyValueFactory property="email" /></cellValueFactory>
            </TableColumn>
            <TableColumn fx:id="colAdresse" text="Adresse" prefWidth="150">
                <cellValueFactory><PropertyValueFactory property="adresse" /></cellValueFactory>
            </TableColumn>
            <TableColumn fx:id="colNumTel" text="Téléphone" prefWidth="120">
                <cellValueFactory><PropertyValueFactory property="numTel" /></cellValueFactory>
            </TableColumn>
        </columns>
    </TableView>

    <HBox spacing="10">
        <Button fx:id="addButton" text="Ajouter" onAction="#handleAjouter"/>
        <Button fx:id="editButton" text="Modifier" onAction="#handleModifier"/>
        <Button fx:id="deleteButton" text="Supprimer" onAction="#handleSupprimer"/>
    </HBox>
</VBox>