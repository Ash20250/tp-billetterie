package dao;

import model.Salle;
import model.Spectacle;

import java.sql.Connection;
import java.sql.PreparedStatement;
import java.sql.ResultSet;
import java.util.ArrayList;
import java.util.List;

public class SpectacleDAO {

    private final SalleDAO salleDAO = new SalleDAO();

    public List<Spectacle> getAllSpectacles() {
        List<Spectacle> spectacles = new ArrayList<>();
        try (Connection conn = DBConnection.getConnection()) {
            String sql = "SELECT id_spectacle, id_salle, titre, date_spectacle, heure_spectacle, duree, langue, age_minimum FROM spectacle";
            PreparedStatement stmt = conn.prepareStatement(sql);
            ResultSet rs = stmt.executeQuery();

            while (rs.next()) {
                Salle salle = salleDAO.getSalleById(rs.getInt("id_salle"));
                Spectacle spectacle = new Spectacle(
                        rs.getInt("id_spectacle"),
                        rs.getString("titre"),
                        (rs.getDate("date_spectacle") != null) ? rs.getDate("date_spectacle").toLocalDate() : null,
                        (rs.getTime("heure_spectacle") != null) ? rs.getTime("heure_spectacle").toLocalTime() : null,
                        salle,
                        rs.getInt("duree"),
                        rs.getString("langue"),
                        rs.getInt("age_minimum")
                );
                spectacles.add(spectacle);
            }
        } catch (Exception e) {
            System.out.println("Erreur getAllSpectacles : " + e.getMessage());
        }
        return spectacles;
    }

    public Spectacle getSpectacleById(int id) {
        Spectacle spectacle = null;
        try (Connection conn = DBConnection.getConnection()) {
            String sql = "SELECT id_spectacle, id_salle, titre, date_spectacle, heure_spectacle, duree, langue, age_minimum FROM spectacle WHERE id_spectacle = ?";
            PreparedStatement stmt = conn.prepareStatement(sql);
            stmt.setInt(1, id);
            ResultSet rs = stmt.executeQuery();

            if (rs.next()) {
                Salle salle = salleDAO.getSalleById(rs.getInt("id_salle"));
                spectacle = new Spectacle(
                        rs.getInt("id_spectacle"),
                        rs.getString("titre"),
                        (rs.getDate("date_spectacle") != null) ? rs.getDate("date_spectacle").toLocalDate() : null,
                        (rs.getTime("heure_spectacle") != null) ? rs.getTime("heure_spectacle").toLocalTime() : null,
                        salle,
                        rs.getInt("duree"),
                        rs.getString("langue"),
                        rs.getInt("age_minimum")
                );
            }
        } catch (Exception e) {
            System.out.println("Erreur getSpectacleById : " + e.getMessage());
        }
        return spectacle;
    }

    public void addSpectacle(Spectacle spectacle) {
        try (Connection conn = DBConnection.getConnection()) {
            String sql = "INSERT INTO spectacle (id_salle, titre, date_spectacle, heure_spectacle, duree, langue, age_minimum) VALUES (?, ?, ?, ?, ?, ?, ?)";
            PreparedStatement stmt = conn.prepareStatement(sql);
            stmt.setInt(1, spectacle.getSalle().getId_salle());
            stmt.setString(2, spectacle.getTitre());
            stmt.setDate(3, java.sql.Date.valueOf(spectacle.getDate_spectacle()));
            stmt.setTime(4, java.sql.Time.valueOf(spectacle.getHeure_spectacle()));
            stmt.setInt(5, spectacle.getDuree());
            stmt.setString(6, spectacle.getLangue());
            stmt.setInt(7, spectacle.getAge_minimum());
            stmt.executeUpdate();
        } catch (Exception e) {
            System.out.println("Erreur addSpectacle : " + e.getMessage());
        }
    }

    public void updateSpectacle(Spectacle spectacle) {
        try (Connection conn = DBConnection.getConnection()) {
            String sql = "UPDATE spectacle SET id_salle=?, titre=?, date_spectacle=?, heure_spectacle=?, duree=?, langue=?, age_minimum=? WHERE id_spectacle=?";
            PreparedStatement stmt = conn.prepareStatement(sql);
            stmt.setInt(1, spectacle.getSalle().getId_salle());
            stmt.setString(2, spectacle.getTitre());
            stmt.setDate(3, java.sql.Date.valueOf(spectacle.getDate_spectacle()));
            stmt.setTime(4, java.sql.Time.valueOf(spectacle.getHeure_spectacle()));
            stmt.setInt(5, spectacle.getDuree());
            stmt.setString(6, spectacle.getLangue());
            stmt.setInt(7, spectacle.getAge_minimum());
            stmt.setInt(8, spectacle.getId_spectacle());
            stmt.executeUpdate();
        } catch (Exception e) {
            System.out.println("Erreur updateSpectacle : " + e.getMessage());
        }
    }
}
