<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" style="-fx-padding: 25; -fx-background-color: #f8f9fa;"
      prefWidth="650" prefHeight="500"
      xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="view.ListeParticipantsController">

    <children>
        <VBox spacing="5">
            <children>
                <Label text="📊 Gestion des Ventes" style="-fx-font-size: 14px; -fx-text-fill: #8e44ad; -fx-font-weight: bold;"/>
                <Label fx:id="lblTitreSpectacle" text="Participants pour : [Nom du Spectacle]"
                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            </children>
        </VBox>

        <TableView fx:id="tableParticipants" VBox.vgrow="ALWAYS" style="-fx-background-radius: 8; -fx-border-color: #dfe6e9;">
            <columns>
                <TableColumn fx:id="colNom" text="Nom" prefWidth="130" />
                <TableColumn fx:id="colPrenom" text="Prénom" prefWidth="130" />
                <TableColumn fx:id="colPlace" text="Siège / Place" prefWidth="100" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colDateAchat" text="Date d'achat" prefWidth="150" />
                <TableColumn fx:id="colPrix" text="Prix Payé" prefWidth="90" style="-fx-alignment: CENTER-RIGHT;" />
            </columns>
        </TableView>

        <HBox spacing="20" alignment="CENTER_LEFT" style="-fx-padding: 10; -fx-background-color: #ffffff; -fx-background-radius: 5; -fx-border-color: #dfe6e9;">
            <children>
                <Label fx:id="lblTotalVentes" text="Total places : 0" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                <Separator orientation="VERTICAL" />
                <Label fx:id="lblRecette" text="Recette totale : 0.00 €" style="-fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                <Region HBox.hgrow="ALWAYS" />
                <Button text="Fermer" onAction="#handleClose"
                        style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20;"/>
            </children>
        </HBox>
    </children>
</VBox>