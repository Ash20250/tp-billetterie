<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21.0.9"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="src.main.ressources.view.SpectacleFormController"
      spacing="10" alignment="CENTER" style="-fx-padding:20;">

    <Label text="Créer ou modifier un spectacle" style="-fx-font-size:18; -fx-font-weight:bold;"/>

    <HBox spacing="10">
        <Label text="Titre:"/>
        <TextField fx:id="txtTitre" prefWidth="300"/>
    </HBox>

    <HBox spacing="10">
        <Label text="Date:"/>
        <DatePicker fx:id="dateSpectacle"/>
    </HBox>

    <HBox spacing="10">
        <Label text="Heure:"/>
        <TextField fx:id="txtHeure" promptText="HH:mm"/>
    </HBox>

    <HBox spacing="10">
        <Label text="Durée (min):"/>
        <Spinner fx:id="spinnerDuree" prefWidth="80"/>
    </HBox>

    <HBox spacing="10">
        <Label text="Langue:"/>
        <TextField fx:id="txtLangue" prefWidth="150"/>
    </HBox>

    <HBox spacing="10">
        <Label text="Âge minimum:"/>
        <Spinner fx:id="spinnerAgeMinimum" prefWidth="80"/>
    </HBox>

    <HBox spacing="10">
        <Label text="Salle:"/>
        <ComboBox fx:id="comboSalle" prefWidth="250"/>
    </HBox>

    <Button fx:id="btnSave" text="Enregistrer" style="-fx-font-weight:bold;"/>
</VBox>
