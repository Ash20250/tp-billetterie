package view;

import javafx.geometry.Insets;
import javafx.geometry.Pos;
import javafx.scene.Scene;
import javafx.scene.control.Label;
import javafx.scene.layout.VBox;
import javafx.stage.Stage;
import model.Spectacle;


public class SpectacleDetailsView {
    private Spectacle spectacle;

    public SpectacleDetailsView(Spectacle spectacle) {
        this.spectacle = spectacle;
    }

    public void show() {
        Stage stage = new Stage();
        VBox root = new VBox(10);
        root.setPadding(new Insets(15));
        root.setAlignment(Pos.CENTER_LEFT);

        root.getChildren().addAll(
                new Label("Titre : " + spectacle.getTitre()),
                new Label("Salle : " + spectacle.getSalle()),
                new Label("Date : " + spectacle.getDate()),
                new Label("Prix : " + spectacle.getPrix())
        );

        Scene scene = new Scene(root, 300, 200);
        stage.setScene(scene);
        stage.setTitle("Détails du spectacle");
        stage.show();
    }
}
